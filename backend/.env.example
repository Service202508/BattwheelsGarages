# Battwheels OS — Environment Configuration
# Copy to .env and fill in real values for your environment

MONGO_URL="mongodb://localhost:27017"
DB_NAME=battwheels_dev
CORS_ORIGINS="http://localhost:3000"
EMERGENT_LLM_KEY=your_emergent_key_here
JWT_SECRET=CHANGE_ME_generate_a_64_char_hex_secret
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_API_BASE_URL=https://www.zohoapis.in
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
ZOHO_ORGANIZATION_ID=your_zoho_org_id
SENTRY_DSN=
RESEND_API_KEY=
SENDER_EMAIL=noreply@battwheels.com
RAZORPAY_KEY_ID=rzp_test_disabled
RAZORPAY_KEY_SECRET=disabled
RAZORPAY_WEBHOOK_SECRET=disabled
ENVIRONMENT=development
TESTING=0
VAULT_MASTER_KEY=CHANGE_ME_generate_a_64_char_hex_secret
EFI_SYSTEM_PROMPT_OVERRIDE=
TEST_DB_NAME=battwheels_test
